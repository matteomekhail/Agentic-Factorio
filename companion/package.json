{
  "name": "agentic-factorio",
  "version": "0.3.0",
  "description": "AI companion for your Factorio world \u2014 bring Claude, GPT or any LLM into your game",
  "type": "module",
  "license": "MIT",
  "bin": {
    "agentic-factorio": "dist/cli.js"
  },
  "files": [
    "dist",
    "assets"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "play": "tsx src/cli.ts play"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.14",
    "@ai-sdk/openai": "^4.0.13",
    "@clack/prompts": "^1.7.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openrouter/ai-sdk-provider": "^3.0.0",
    "ai": "^7.0.26",
    "picocolors": "^1.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}